{
  "rules": {
    // ===== LIVE SESSIONS (для presence и events) =====
    "liveSessions": {
      "$sessionId": {
        // ===== PRESENCE (статус онлайн) =====
        "presence": {
          ".read": "root.child('members').child($sessionId).child(auth.uid).exists()",
          "$uid": {
            ".write": "auth.uid == $uid || root.child('sessions').child($sessionId).child('dmId').val() == auth.uid",
            ".validate": "newData.hasChildren(['online', 'lastSeen']) && newData.child('online').isBoolean()",
            "online": {
              ".validate": "newData.isBoolean()"
            },
            "lastSeen": {
              ".validate": "newData.isNumber()"
            }
          }
        },

        // ===== EVENTS (для синхронизации игровых событий) =====
        "events": {
          ".read": "root.child('members').child($sessionId).child(auth.uid).exists()",
          ".write": "root.child('members').child($sessionId).child(auth.uid).exists()",
          "$eventId": {
            ".validate": "newData.hasChildren(['type', 'timestamp']) && newData.child('type').isString()",
            "type": {
              ".validate": "newData.isString() && (newData.val() == 'roll' || newData.val() == 'attack' || newData.val() == 'spell' || newData.val() == 'message' || newData.val() == 'action')"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "userId": {
              ".validate": "newData.isString()"
            }
          }
        },

        // ===== MEMBERS INDEX (для быстрого поиска) =====
        "members": {
          "$uid": {
            ".write": "auth.uid == $uid || root.child('sessions').child($sessionId).child('dmId').val() == auth.uid",
            ".read": "root.child('members').child($sessionId).child(auth.uid).exists()"
          }
        }
      }
    },

    // ===== FIRESTORE SESSIONS (для метаданных) =====
    "sessions": {
      "$sessionId": {
        ".read": "root.child('members').child($sessionId).child(auth.uid).exists()",
        ".write": false,

        "events": {
          ".read": "root.child('members').child($sessionId).child(auth.uid).exists()",
          ".write": "root.child('members').child($sessionId).child(auth.uid).exists()",
          "$eventId": {
            ".validate": "newData.hasChildren(['type', 'timestamp']) && newData.child('type').isString()",
            "type": {
              ".validate": "newData.isString() && (newData.val() == 'roll' || newData.val() == 'attack' || newData.val() == 'spell' || newData.val() == 'message' || newData.val() == 'action')"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "userId": {
              ".validate": "newData.isString()"
            }
          }
        },

        "members": {
          "$uid": {
            ".write": "auth.uid == $uid || root.child('sessions').child($sessionId).child('dmId').val() == auth.uid",
            ".read": "root.child('members').child($sessionId).child(auth.uid).exists()"
          }
        }
      }
    },

    // ===== SESSION METADATA (для кэша) =====
    "sessionMetadata": {
      "$sessionId": {
        ".read": true,
        ".write": false
      }
    },

    // ===== DEFAULT DENY =====
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}


{
  "rules": {
    // ===== SESSIONS (основные данные сессий) =====
    "sessions": {
      "$sessionId": {
        ".read": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists() || root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",
        ".write": "root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",
        ".validate": "newData.hasChildren(['id', 'dmId', 'name', 'joinCode'])",

        "members": {
          ".read": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists() || root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",
          ".write": false,
          "$userId": {
            ".write": "root.child('sessions').child($sessionId).child('dmId').val() === auth.uid || $userId === auth.uid"
          }
        },

        "updatedAt": {
          ".write": "root.child('sessions').child($sessionId).child('dmId').val() === auth.uid"
        }
      }
    },

    // ===== REQUESTS (запросы бросков) =====
    "requests": {
      "$sessionId": {
        ".read": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists() || root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",
        ".write": "root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",

        "$requestId": {
          ".validate": "newData.hasChildren(['id', 'characterId', 'characterName', 'type', 'formula', 'status'])"
        }
      }
    },

    // ===== PRESENCE (статус онлайн членов) =====
    "presence": {
      "$sessionId": {
        ".read": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists() || root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",

        "$userId": {
          ".write": "$userId === auth.uid",
          ".validate": "newData.hasChildren(['userId', 'lastSeen'])"
        }
      }
    },

    // ===== EVENTS (игровые события в реальном времени) =====
    "events": {
      "$sessionId": {
        ".read": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists() || root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",
        ".write": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists() || root.child('sessions').child($sessionId).child('dmId').val() === auth.uid",

        "$eventId": {
          ".validate": "newData.hasChildren(['type', 'timestamp', 'userId'])",
          "type": {
            ".validate": "newData.isString() && ['roll', 'attack', 'spell', 'message', 'action', 'update'].includes(newData.val())"
          },
          "timestamp": {
            ".validate": "newData.isNumber()"
          },
          "userId": {
            ".validate": "newData.isString()"
          }
        }
      }
    },

    // ===== LIVE SESSIONS (для совместимости) =====
    "liveSessions": {
      "$sessionId": {
        "presence": {
          ".read": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists()",
          "$uid": {
            ".write": "auth.uid == $uid || root.child('sessions').child($sessionId).child('dmId').val() == auth.uid"
          }
        },
        "members": {
          "$uid": {
            ".read": "root.child('sessions').child($sessionId).child('members').child(auth.uid).exists()"
          }
        }
      }
    },

    // ===== SESSION METADATA (кэш метаданных) =====
    "sessionMetadata": {
      "$sessionId": {
        ".read": true,
        ".write": false
      }
    },

    // ===== DEFAULT DENY (по умолчанию отклоняем) =====
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}

